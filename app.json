{
    "expo": {
        "name": "finyo",
        "slug": "finyo",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/images/icon.png",
        "scheme": "finyo",
        "userInterfaceStyle": "automatic",
        "splash": {
            "image": "./assets/images/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
        },
        "assetBundlePatterns": ["**/*"],
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.anonymous.finyo"
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/images/adaptive-icon.png",
                "backgroundColor": "#ffffff"
            },
            "package": "com.anonymous.finyo"
        },
        "web": {
            "bundler": "metro",
            "output": "server",
            "favicon": "./assets/images/favicon.png"
        },
        "plugins": [
            "expo-router",
            "@clerk/expo",
            "expo-secure-store",
            "expo-web-browser",
            "expo-font",
            "@prisma/react-native",
            "expo-localization",
            [
                "expo-image",
                {
                    "disableLibdav1d": true
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true
        },
        "extra": {
            "router": {},
            "eas": {
                "projectId": "fc715b0d-569f-49cc-bc5a-962165a2c6ab"
            }
        },
        "owner": "luanstavaress-organization"
    }
}
